// GitHub Copilot CLI config for the `copilot` backend in Docker.
//
// The copilot backend authenticates with the GitHub OAuth token (gho_...)
// or fine-grained PAT ("Copilot Requests" permission) stored under
// "copilotTokens". docker-compose mounts this file to
// /mnt/copilot-config.json and the entrypoint installs it at
// /home/bench/.copilot/config.json so no env var is needed.
//
// EASIEST — reuse your existing login (recommended):
//     cp ~/.copilot/config.json docker/copilot-config.json
//
// ALTERNATIVE — skip this file entirely and set COPILOT_GITHUB_TOKEN
// (or GH_TOKEN / GITHUB_TOKEN) in the environment instead.
//
// This .example is just a skeleton; replace YOUR_LOGIN and the token.
{
  "copilotTokens": {
    "https://github.com:YOUR_LOGIN": "gho_REPLACE_WITH_YOUR_TOKEN"
  },
  "lastLoggedInUser": { "host": "https://github.com", "login": "YOUR_LOGIN" },
  "loggedInUsers": [ { "host": "https://github.com", "login": "YOUR_LOGIN" } ]
}
